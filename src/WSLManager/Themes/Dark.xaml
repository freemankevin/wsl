<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Dark Theme Colors -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="#90CAF9"/>
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="#42A5F5"/>
    <SolidColorBrush x:Key="AccentBrush" Color="#FF80AB"/>
    <SolidColorBrush x:Key="BackgroundBrush" Color="#121212"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#1E1E1E"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#E0E0E0"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#9E9E9E"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#333333"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="#81C784"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#FFB74D"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="#E57373"/>
    <SolidColorBrush x:Key="ChartGridBrush" Color="#333333"/>
    <SolidColorBrush x:Key="LogBackgroundBrush" Color="#282A36"/>
    <SolidColorBrush x:Key="LogToolbarBrush" Color="#44475A"/>
    <FontFamily x:Key="UiFontFamily">pack://application:,,,/Fonts/Inter-VariableFont_opsz,wght.ttf#Inter, pack://application:,,,/Fonts/NotoSansSC-VariableFont_wght.ttf#Noto Sans SC, Segoe UI, Microsoft YaHei</FontFamily>
    <FontFamily x:Key="MonoFontFamily">pack://application:,,,/Fonts/JetBrainsMono-VariableFont_wght.ttf#JetBrains Mono, Consolas, Courier New</FontFamily>
</ResourceDictionary>
